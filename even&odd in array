#include <stdio.h>

int main() {
    int arr[100]; 
    int size, i;
    int even_count = 0, odd_count = 0;
    printf("Enter the size of the array: ");
    scanf("%d", &size);
    printf("Enter the elements of the array: ");
    for (i = 0; i < size; i++) {
        scanf("%d", &arr[i]);
    }
    for (i = 0; i < size; i++) {
        if (arr[i] % 2 == 0) {
            even_count++; 
        } else {
            odd_count++;
        }
    }
