#include <stdio.h>
int linearSearch(int arr[], int size, int target) {
    for (int i = 0; i < size; i++) {
        if (arr[i] == target) {
            return i;
        }
    }
    return -1;
}

int main() {
    int array[100], target, c, n, position;

    printf("Enter number of elements in array: ");
    scanf("%d", &n);

    printf("Enter %d integer(s) (one per line): \n", n);
    for (c = 0; c < n; c++) {
        scanf("%d", &array[c]);
    }

    printf("Enter a number to search: ");
    scanf("%d", &target);
    position = linearSearch(array, n, target);
    if (position != -1) {
        printf("%d is present at location %d (1-based indexing).\n", target, position + 1);
    } else {
        printf("%d isn't present in the array.\n", target);
    }

    return 0;
}
