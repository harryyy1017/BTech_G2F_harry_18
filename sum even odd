#include <stdio.h>

int main() {
    int i, n, odd_sum = 0, even_sum = 0;

    // Prompt the user to enter the limit
    printf("Enter the value of n: ");
    scanf("%d", &n);

    // Loop from 1 to n
    for (i = 1; i <= n; i++) {
        // Check if the current number is even or odd
        if (i % 2 == 0) {
            even_sum += i; // Add to even sum
        } else {
            odd_sum += i; // Add to odd sum
        }
    }

    // Print the results
    printf("Sum of all even numbers up to %d = %d\\n", n, even_sum);
    printf("Sum of all odd numbers up to %d = %d\\n", n, odd_sum);

    return 0;
}
