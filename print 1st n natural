#include <stdio.h>

int main() {
    int i, n;

    // Prompt user for input
    printf("Enter a positive integer (n): ");
    scanf("%d", &n);

    // Check if n is a positive number
    if (n <= 0) {
        printf("Please enter a positive number for n.\\n");
        return 1; // Exit with an error code
    }

    // Print the natural numbers
    printf("Natural numbers from 1 to %d are: ", n);
    for (i = 1; i <= n; i++) {
        printf("%d ", i);
    }

    printf("\\n"); // Print a new line for better formatting
    return 0;
}
