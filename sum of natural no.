#include <stdio.h>

int main() {
    int n, i, sum = 0;

    // Prompt the user for input
    printf("Enter a positive integer: ");
    scanf("%d", &n);

    // Calculate the sum using a for loop
    for (i = 1; i <= n; ++i) {
        sum += i; // Equivalent to sum = sum + i;
    }

    // Display the result
    printf("Sum of the first %d natural numbers is: %d\n", n, sum);

    return 0;
}
