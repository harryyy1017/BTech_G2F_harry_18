#include <stdio.h>

int main() {
    long long num;
    int digit_to_count, count = 0, last_digit;
    long long original_num;
    printf("Enter a number: ");
    scanf("%lld", &num);
    original_num = num;
    printf("Enter the digit to count (0-9): ");
    scanf("%d", &digit_to_count);
    if (original_num == 0 && digit_to_count == 0) {
        count = 1;
    } else {
        if (num < 0) {
            num = -num;
        }
        while (num != 0) {
            last_digit = num % 10;
            if (last_digit == digit_to_count) {
                count++;
            }
            num /= 10;
        }
    }
    printf("The digit %d appears %d time(s) in %lld.\n", digit_to_count, count, original_num);
    return 0;
}
